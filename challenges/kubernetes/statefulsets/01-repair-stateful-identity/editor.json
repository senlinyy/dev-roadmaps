      { "path": ["spec", "replicas"], "equals": 1, "label": "replica count" },
      { "path": ["spec", "selector", "matchLabels", "app.kubernetes.io/name"], "equals": "notification-postgres", "label": "selector label" },
      { "path": ["spec", "template", "metadata", "labels", "app.kubernetes.io/name"], "equals": "notification-postgres", "label": "Pod template label" },
