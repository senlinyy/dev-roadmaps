{
  "language": "yaml",
  "filename": "webhook-receiver-deployment.yaml",
  "completionProfile": "kubernetes",
  "initialValue": "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: webhook-receiver\n  namespace: customer-notifications\nspec:\n  replicas: 2\n  selector:\n    matchLabels:\n      app: webhook-receiver\n  template:\n    metadata:\n      labels:\n        app: webhook-receiver\n    spec:\n      containers:\n        - name: api\n          image: ghcr.io/customer-notifications/webhook-receiver:1.8.0\n          ports:\n            - name: https\n              containerPort: 8443\n",
  "grader": {
    "strategy": "yaml-paths",
    "expected": [
      { "path": ["spec", "template", "spec", "volumes", 0, "name"], "equals": "notification-webhook-tls", "label": "TLS volume name" },
      { "path": ["spec", "template", "spec", "volumes", 0, "secret", "secretName"], "equals": "notification-webhook-tls", "label": "TLS Secret source" },
      { "path": ["spec", "template", "spec", "volumes", 0, "secret", "items"], "containsObject": { "key": "tls.crt", "path": "server.crt" }, "label": "certificate file projection" },
      { "path": ["spec", "template", "spec", "volumes", 0, "secret", "items"], "containsObject": { "key": "tls.key", "path": "server.key" }, "label": "private key file projection" },
      { "path": ["spec", "template", "spec", "containers", 0, "name"], "equals": "api", "label": "API container" },
      { "path": ["spec", "template", "spec", "containers", 0, "image"], "equals": "ghcr.io/customer-notifications/webhook-receiver:1.8.0", "label": "approved receiver image" },
      { "path": ["spec", "template", "spec", "containers", 0, "volumeMounts"], "containsObject": { "name": "notification-webhook-tls", "mountPath": "/etc/notification/tls", "readOnly": true }, "label": "read-only TLS mount" }
    ]
  }
}
