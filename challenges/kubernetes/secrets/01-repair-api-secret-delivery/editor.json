{
  "language": "yaml",
  "filename": "notification-api-deployment.yaml",
  "completionProfile": "kubernetes",
  "initialValue": "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: notification-api\n  namespace: customer-notifications\nspec:\n  replicas: 3\n  selector:\n    matchLabels:\n      app: notification-api\n  template:\n    metadata:\n      labels:\n        app: notification-api\n    spec:\n      containers:\n        - name: api\n          image: ghcr.io/customer-notifications/notification-api:1.8.0\n          ports:\n            - name: http\n              containerPort: 8080\n",
  "grader": {
    "strategy": "yaml-paths",
    "expected": [
      { "path": ["spec", "template", "spec", "containers", 0, "name"], "equals": "api", "label": "API container" },
      { "path": ["spec", "template", "spec", "containers", 0, "image"], "equals": "ghcr.io/customer-notifications/notification-api:1.8.0", "label": "approved API image" },
      { "path": ["spec", "template", "spec", "containers"], "maxItems": 1, "label": "single approved API container" },
      { "path": ["spec", "template", "spec", "containers", 0, "envFrom"], "exists": false, "label": "no bulk Secret import" },
      { "path": ["spec", "template", "spec", "containers", 0, "env"], "containsObject": { "name": "DATABASE_URL", "valueFrom": { "secretKeyRef": { "name": "notification-api-secrets", "key": "DATABASE_URL" } } }, "label": "database Secret reference" },
      { "path": ["spec", "template", "spec", "containers", 0, "env"], "containsObject": { "name": "WEBHOOK_SIGNING_KEY", "valueFrom": { "secretKeyRef": { "name": "notification-api-secrets", "key": "WEBHOOK_SIGNING_KEY" } } }, "label": "webhook Secret reference" },
      { "path": ["spec", "template", "spec", "containers", 0, "env"], "minItems": 2, "maxItems": 2, "label": "only the two approved credential variables" },
      { "path": ["spec", "template", "spec", "containers", 0, "env", 0, "value"], "exists": false, "label": "no literal first credential value" },
      { "path": ["spec", "template", "spec", "containers", 0, "env", 1, "value"], "exists": false, "label": "no literal second credential value" }
    ]
  }
}
