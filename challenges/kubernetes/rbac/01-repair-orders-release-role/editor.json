{
  "language": "yaml",
  "filename": "orders-release-role.yaml",
  "completionProfile": "kubernetes",
  "initialValue": "apiVersion: rbac.authorization.k8s.io/v1\nkind: Role\nmetadata:\n  name: orders-release\n  labels:\n    app.kubernetes.io/part-of: orders-release\n",
  "grader": {
    "strategy": "yaml-paths",
    "expected": [
      { "path": ["apiVersion"], "equals": "rbac.authorization.k8s.io/v1", "label": "RBAC API version" },
      { "path": ["kind"], "equals": "Role", "label": "Role kind" },
      { "path": ["metadata", "name"], "equals": "orders-release", "label": "release Role name" },
      { "path": ["metadata", "namespace"], "equals": "orders", "label": "orders namespace" },
      { "path": ["metadata", "labels", "app.kubernetes.io/part-of"], "equals": "orders-release", "label": "approved ownership label" },
      { "path": ["rules"], "containsObject": { "apiGroups": ["apps"], "resources": ["deployments", "replicasets"], "verbs": ["get", "list", "watch", "patch", "update"] }, "label": "workload release rule" },
      { "path": ["rules"], "containsObject": { "apiGroups": [""], "resources": ["pods"], "verbs": ["get", "list", "watch"] }, "label": "Pod observation rule" },
      { "path": ["rules"], "minItems": 2, "maxItems": 2, "label": "only the two approved release rules" }
    ]
  }
}
