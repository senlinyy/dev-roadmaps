{
  "language": "yaml",
  "filename": "service.yaml",
  "completionProfile": "kubernetes",
  "initialValue": "apiVersion: v1\nkind: Service\nmetadata:\n  name: orders-api\n  namespace: orders\n  labels:\n    app.kubernetes.io/part-of: orders\nspec:\n",
  "grader": {
    "strategy": "yaml-paths",
    "expected": [
      { "path": ["apiVersion"], "equals": "v1", "label": "Service API version" },
      { "path": ["kind"], "equals": "Service", "label": "resource kind" },
      { "path": ["metadata", "name"], "equals": "orders-api", "label": "Service name" },
      { "path": ["metadata", "namespace"], "equals": "orders", "label": "orders namespace" },
      { "path": ["spec", "type"], "equals": "ClusterIP", "label": "internal Service type" },
      { "path": ["spec", "selector", "app.kubernetes.io/name"], "equals": "orders-api", "label": "orders API selector" },
      { "path": ["spec", "ports"], "containsObject": { "name": "http", "protocol": "TCP", "port": 80, "targetPort": 3000 }, "label": "caller and Pod port contract" }
    ]
  }
}
