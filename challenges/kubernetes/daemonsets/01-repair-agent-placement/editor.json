{
  "language": "yaml",
  "filename": "notification-log-agent-daemonset.yaml",
  "completionProfile": "kubernetes",
  "initialValue": "apiVersion: apps/v1\nkind: DaemonSet\nmetadata:\n  name: notification-log-agent\n  namespace: observability\nspec:\n  template:\n    spec:\n      containers: []\n",
  "grader": {
    "strategy": "yaml-paths",
    "expected": [
      { "path": ["apiVersion"], "equals": "apps/v1", "label": "DaemonSet API version" },
      { "path": ["kind"], "equals": "DaemonSet", "label": "DaemonSet kind" },
      { "path": ["metadata", "name"], "equals": "notification-log-agent", "label": "DaemonSet name" },
      { "path": ["metadata", "namespace"], "equals": "observability", "label": "observability namespace" },
      { "path": ["spec", "selector", "matchLabels", "app.kubernetes.io/name"], "equals": "notification-log-agent", "label": "selector label" },
      { "path": ["spec", "template", "metadata", "labels", "app.kubernetes.io/name"], "equals": "notification-log-agent", "label": "Pod template label" },
      { "path": ["spec", "template", "spec", "nodeSelector", "devpolaris.io/node-pool"], "equals": "app", "label": "application node pool" },
      { "path": ["spec", "template", "spec", "tolerations"], "containsObject": { "key": "dedicated", "operator": "Equal", "value": "app", "effect": "NoSchedule" }, "label": "application node taint toleration" }
    ]
  }
}
