{
  "language": "yaml",
  "filename": "notification-api-deployment.yaml",
  "completionProfile": "kubernetes",
  "initialValue": "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: notification-api\n  namespace: notifications\nspec:\n  replicas: 1\n",
  "grader": {
    "strategy": "yaml-paths",
    "expected": [
      { "path": ["apiVersion"], "equals": "apps/v1", "label": "Deployment API version" },
      { "path": ["kind"], "equals": "Deployment", "label": "Deployment kind" },
      { "path": ["metadata", "name"], "equals": "notification-api", "label": "Deployment name" },
      { "path": ["metadata", "namespace"], "equals": "notifications", "label": "notifications namespace" },
      { "path": ["spec", "replicas"], "equals": 3, "label": "desired replica count" },
      { "path": ["spec", "selector", "matchLabels", "app.kubernetes.io/name"], "equals": "notification-api", "label": "selector application label" },
      { "path": ["spec", "selector", "matchLabels", "app.kubernetes.io/component"], "equals": "api", "label": "selector component label" },
      { "path": ["spec", "template", "metadata", "labels", "app.kubernetes.io/name"], "equals": "notification-api", "label": "template application label" },
      { "path": ["spec", "template", "metadata", "labels", "app.kubernetes.io/component"], "equals": "api", "label": "template component label" },
      { "path": ["spec", "template", "spec", "containers", 0, "name"], "equals": "api", "label": "container name" },
      { "path": ["spec", "template", "spec", "containers", 0, "image"], "equals": "ghcr.io/customer-notification/notification-api:2026.06.14-1", "label": "approved image" },
      { "path": ["spec", "template", "spec", "containers", 0, "ports"], "containsObject": { "name": "http", "containerPort": 8080 }, "label": "named application port" }
    ]
  }
}
