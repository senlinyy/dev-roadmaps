{
  "language": "hcl",
  "completionProfile": "terraform-aws",
  "activeFile": "s3.tf",
  "files": [
    {
      "filename": "main.tf",
      "readOnly": true,
      "initialValue": "terraform {\n  required_providers {\n    aws = {\n      source  = \"hashicorp/aws\"\n      version = \"~> 6.0\"\n    }\n  }\n}\n\nprovider \"aws\" {\n  region = \"eu-west-2\"\n}\n"
    },
    {
      "filename": "variables.tf",
      "initialValue": "variable \"environment\" {\n  default = \"dev\"\n}\n\nlocals {\n  bucket_name = \"\"\n  common_tags = {\n    service     = \"plan-preview\"\n    environment = var.environment\n    managed_by  = \"devpolaris\"\n  }\n}\n"
    },
    {
      "filename": "s3.tf",
      "initialValue": "resource \"aws_s3_bucket\" \"preview\" {\n  bucket = local.bucket_name\n}\n\nresource \"aws_s3_bucket_public_access_block\" \"preview\" {\n  bucket = \"\"\n}\n"
    },
    {
      "filename": "outputs.tf",
      "initialValue": "output \"bucket_name\" {\n  value = \"\"\n}\n"
    }
  ],
  "grader": {
    "strategy": "regex-all",
    "expected": [
      {
        "file": "variables.tf",
        "pattern": "variable\\s+\"environment\"\\s*\\{[\\s\\S]*default\\s*=\\s*\"staging\"",
        "label": "environment input targets staging"
      },
      {
        "file": "variables.tf",
        "pattern": "bucket_name\\s*=\\s*\"dp-preview-\\$\\{var\\.environment\\}-artifacts\"",
        "label": "bucket name is derived from the environment variable"
      },
      {
        "file": "s3.tf",
        "pattern": "resource\\s+\"aws_s3_bucket\"\\s+\"preview\"\\s*\\{[\\s\\S]*bucket\\s*=\\s*local\\.bucket_name[\\s\\S]*tags\\s*=\\s*local\\.common_tags",
        "label": "preview bucket uses local name and tags"
      },
      {
        "file": "s3.tf",
        "pattern": "resource\\s+\"aws_s3_bucket_public_access_block\"\\s+\"preview\"\\s*\\{[\\s\\S]*bucket\\s*=\\s*aws_s3_bucket\\.preview\\.bucket[\\s\\S]*restrict_public_buckets\\s*=\\s*true",
        "label": "public access block references the bucket and restricts public buckets"
      },
      {
        "file": "s3.tf",
        "pattern": "resource\\s+\"aws_s3_bucket_public_access_block\"\\s+\"preview\"\\s*\\{[\\s\\S]*block_public_acls\\s*=\\s*true[\\s\\S]*block_public_policy\\s*=\\s*true[\\s\\S]*ignore_public_acls\\s*=\\s*true[\\s\\S]*restrict_public_buckets\\s*=\\s*true",
        "label": "all four S3 public access controls are enabled"
      },
      {
        "file": "outputs.tf",
        "pattern": "output\\s+\"bucket_name\"\\s*\\{[\\s\\S]*value\\s*=\\s*aws_s3_bucket\\.preview\\.bucket",
        "label": "bucket output follows the resource attribute"
      }
    ]
  }
}
