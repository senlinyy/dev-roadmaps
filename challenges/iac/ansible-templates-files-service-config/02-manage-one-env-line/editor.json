      "initialValue": "- name: Set orders API port\n  ansible.builtin.shell: echo \"ORDERS_API_PORT=8080\" >> /etc/default/devpolaris-orders-api\n"
    }
  ],
  "grader": {
    "strategy": "yaml-paths",
    "expected": [
      {
        "file": "roles/orders_web/tasks/main.yml",
        "path": [
