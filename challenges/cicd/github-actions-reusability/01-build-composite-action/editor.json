{
  "language": "yaml",
  "filename": "action.yml",
  "completionProfile": "github-actions",
  "initialValue": "name: Setup and Build\ndescription: Bundles Node setup and dependency installation\n\nruns:\n  steps:\n    - name: Install Dependencies\n      run: npm ci\n    - name: Run Build\n      run: npm run build",
  "grader": {
    "strategy": "yaml-paths",
    "expected": [
      {
        "path": ["runs", "using"],
        "type": "string",
        "equals": "composite",
        "label": "runs.using is composite"
      },
      {
        "path": ["runs", "steps"],
        "containsObject": {
          "run": "npm ci",
          "shell": "bash"
        },
        "label": "dependency installation runs with bash"
      },
      {
        "path": ["runs", "steps"],
        "containsObject": {
          "run": "npm run build",
          "shell": "bash"
        },
        "label": "build runs with bash"
      },
      {
        "path": ["runs", "steps"],
        "type": "array",
        "maxItems": 2,
        "label": "composite action keeps the two intended steps"
      }
    ]
  }
}
