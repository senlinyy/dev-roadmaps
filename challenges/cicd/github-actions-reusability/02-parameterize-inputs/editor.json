{
  "language": "yaml",
  "filename": "action.yml",
  "completionProfile": "github-actions",
  "initialValue": "name: Setup and Build\ndescription: Bundles Node setup and npm build\n\nruns:\n  using: \"composite\"\n  steps:\n    - name: Setup Node\n      uses: actions/setup-node@v4\n      with:\n        node-version: '22'\n    - name: Install Dependencies\n      run: npm ci\n      shell: bash",
  "grader": {
    "strategy": "yaml-paths",
    "expected": [
      {
        "path": ["inputs", "node-version"],
        "type": "object",
        "label": "node-version input exists"
      },
      {
        "path": ["inputs", "node-version", "default"],
        "type": "string",
        "equals": "22",
        "label": "node-version input keeps default 22"
      },
      {
        "path": ["runs", "steps", 0, "with", "node-version"],
        "type": "string",
        "contains": "inputs.node-version",
        "label": "setup-node consumes the node-version input"
      }
    ]
  }
}
