{
  "language": "yaml",
  "filename": ".github/workflows/rolling-deploy.yml",
  "completionProfile": "github-actions",
  "initialValue": "name: Rolling Deploy Orders API\non:\n  workflow_dispatch:\n    inputs:\n      image_digest:\n        description: Tested image digest\n        required: true\n        type: string\n\njobs:\n  rollout:\n    runs-on: ubuntu-latest\n    steps:\n      - run: ./scripts/update-ecs-service.sh orders-api-prod\n      - run: ./scripts/register-task-definition.sh \"${{ inputs.image_digest }}\"\n      - run: ./scripts/check-public-version.sh orders-api:42",
  "grader": {
    "strategy": "yaml-paths",
    "expected": [
      {
        "path": ["jobs", "rollout", "environment", "name"],
        "type": "string",
        "equals": "production",
        "label": "rollout uses the production environment"
      },
      {
        "path": ["jobs", "rollout", "environment", "url"],
        "type": "string",
        "equals": "https://orders-api.devpolaris.example",
        "label": "production environment has the service URL"
      },
      {
        "path": ["jobs", "rollout", "steps"],
        "containsObject": {
          "run": "./scripts/register-task-definition.sh \"${{ inputs.image_digest }}\""
        },
        "label": "rollout registers the task definition"
      },
      {
        "path": ["jobs", "rollout", "steps"],
        "containsObject": {
          "run": "./scripts/update-ecs-service.sh orders-api-prod"
        },
        "label": "rollout updates the ECS service"
      },
      {
        "path": ["jobs", "rollout", "steps"],
        "containsObject": {
          "run": "./scripts/wait-target-health.sh orders-api-prod"
        },
        "label": "rollout waits for target health"
      },
      {
        "path": ["jobs", "rollout", "steps"],
        "containsObject": {
          "run": "./scripts/watch-rollout.sh orders-api-prod --minutes 15"
        },
        "label": "rollout watches service signals"
      }
    ]
  }
}
