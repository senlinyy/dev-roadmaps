{
  "cwd": "/home/dev",
  "env": {
    "USER": "dev",
    "HOME": "/home/dev"
  },
  "fs": {
    "/home/dev": {
      "type": "dir"
    }
  },
  "commandModules": [
    "aws"
  ],
  "cloud": {
    "aws": {
      "accountId": "123456789012",
      "region": "us-east-1",
      "userArn": "arn:aws:iam::123456789012:user/devpolaris-operator",
      "s3Buckets": [
        {
          "name": "devpolaris-orders-exports-prod",
          "region": "us-east-1",
          "tags": {
            "service": "devpolaris-orders-api",
            "env": "prod"
          }
        }
      ]
    }
  },
  "grader": {
    "strategy": "contains",
    "source": "all-stdout",
    "expected": [
      "123456789012",
      "us-east-1",
      "devpolaris-orders-exports-prod"
    ],
    "requireCommands": [
      "aws"
    ],
    "minCommandCount": 3,
    "loose": true
  }
}
