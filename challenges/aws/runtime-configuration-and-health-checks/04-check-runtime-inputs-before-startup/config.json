{
  "cwd": "/home/dev",
  "env": {
    "USER": "dev",
    "HOME": "/home/dev"
  },
  "fs": {
    "/home/dev": {
      "type": "dir"
    }
  },
  "commandModules": [
    "aws"
  ],
  "cloud": {
    "aws": {
      "accountId": "123456789012",
      "region": "us-east-1",
      "userArn": "arn:aws:iam::123456789012:user/devpolaris-learner",
      "secrets": [
        {
          "name": "/devpolaris/orders-api/prod/database-url",
          "arn": "arn:aws:secretsmanager:us-east-1:123456789012:secret:/devpolaris/orders-api/prod/database-url-a1b2c3",
          "region": "us-east-1",
          "kmsKeyId": "arn:aws:kms:us-east-1:123456789012:key/orders-api-secrets",
          "tags": {
            "service": "devpolaris-orders-api",
            "env": "prod"
          }
        }
      ],
      "iamRoles": [
        {
          "roleName": "devpolaris-orders-api-prod-execution-role",
          "arn": "arn:aws:iam::123456789012:role/devpolaris-orders-api-prod-execution-role",
          "trustPrincipals": [
            "ecs-tasks.amazonaws.com"
          ],
          "attachedPolicies": [
            {
              "policyName": "devpolaris-orders-api-prod-execution",
              "policyArn": "arn:aws:iam::123456789012:policy/devpolaris-orders-api-prod-execution",
              "statements": [
                {
                  "effect": "Allow",
                  "actions": [
                    "secretsmanager:GetSecretValue"
                  ],
                  "resources": [
                    "arn:aws:secretsmanager:us-east-1:123456789012:secret:/devpolaris/orders-api/prod/database-url-a1b2c3"
                  ]
                },
                {
                  "effect": "Allow",
                  "actions": [
                    "logs:CreateLogStream",
                    "logs:PutLogEvents"
                  ],
                  "resources": [
                    "arn:aws:logs:us-east-1:123456789012:log-group:/ecs/devpolaris-orders-api:*"
                  ]
                }
              ]
            }
          ]
        }
      ],
      "ecsTaskDefinitions": [
        {
          "taskDefinitionArn": "arn:aws:ecs:us-east-1:123456789012:task-definition/devpolaris-orders-api:43",
          "family": "devpolaris-orders-api",
          "revision": 43,
          "taskRoleArn": "arn:aws:iam::123456789012:role/devpolaris-orders-api-prod-task-role",
          "executionRoleArn": "arn:aws:iam::123456789012:role/devpolaris-orders-api-prod-execution-role",
          "networkMode": "awsvpc",
          "requiresCompatibilities": [
            "FARGATE"
          ],
          "cpu": "512",
          "memory": "1024",
          "containerDefinitions": [
            {
              "name": "orders-api",
              "image": "123456789012.dkr.ecr.us-east-1.amazonaws.com/devpolaris-orders-api:2026-05-04.4",
              "portMappings": [
                {
                  "containerPort": 3000,
                  "hostPort": 3000,
                  "protocol": "tcp"
                }
              ],
              "secrets": [
                {
                  "name": "DATABASE_URL",
                  "valueFrom": "arn:aws:secretsmanager:us-east-1:123456789012:secret:/devpolaris/orders-api/prod/database-url-a1b2c3"
                }
              ],
              "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                  "awslogs-group": "/ecs/devpolaris-orders-api",
                  "awslogs-region": "us-east-1",
                  "awslogs-stream-prefix": "orders-api"
                }
              }
            }
          ]
        }
      ]
    }
  },
  "grader": {
    "strategy": "contains",
    "source": "all-stdout",
    "expected": [
      "devpolaris-orders-api:43",
      "DATABASE_URL",
      "devpolaris-orders-api-prod-execution-role",
      "/devpolaris/orders-api/prod/database-url",
      "arn:aws:secretsmanager:us-east-1:123456789012:secret:/devpolaris/orders-api/prod/database-url-a1b2c3",
      "secretsmanager:GetSecretValue",
      "\"EvalDecision\": \"allowed\""
    ],
    "requireCommands": [
      "aws"
    ],
    "minCommandCount": 3,
    "loose": true
  }
}
