{
  "cwd": "/home/dev",
  "env": {
    "USER": "dev",
    "HOME": "/home/dev"
  },
  "fs": {
    "/home/dev": {
      "type": "dir"
    }
  },
  "commandModules": [
    "azure"
  ],
  "cloud": {
    "azure": {
      "tenantId": "tenant-devpolaris",
      "subscriptionId": "sub-devpolaris-training",
      "currentSubscription": "sub-devpolaris-training",
      "defaultLocation": "eastus",
      "resourceGroups": []
    }
  },
  "grader": {
    "strategy": "contains",
    "source": "all-stdout",
    "expected": [
      "sub-devpolaris-training",
      "tenant-devpolaris",
      "DevPolaris Training"
    ],
    "requireCommands": [
      "az"
    ],
    "minCommandCount": 1,
    "loose": true
  }
}
