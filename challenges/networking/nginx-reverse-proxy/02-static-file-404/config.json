{
  "cwd": "/home/dev",
  "env": { "USER": "dev", "HOME": "/home/dev" },
  "fs": {
    "/home/dev": { "type": "dir" },
    "/home/dev/reports": { "type": "dir" },
    "/etc/nginx": { "type": "dir" },
    "/etc/nginx/sites-available": { "type": "dir" },
    "/etc/nginx/sites-available/docs.conf": {
      "type": "file",
      "content": "server {\n    listen 80;\n    server_name docs.example.com;\n    root /var/www/docs;\n    index index.html;\n\n    location / {\n        try_files $uri $uri/ =404;\n    }\n}\n"
    },
    "/var/www": { "type": "dir" },
    "/var/www/docs": { "type": "dir" },
    "/var/www/docs/index.html": {
      "type": "file",
      "content": "<!doctype html><html><head><title>Docs SPA</title></head><body><div id=\"app\"></div><script src=\"/assets/app.js\"></script></body></html>\n"
    },
    "/var/www/docs/assets": { "type": "dir" },
    "/var/www/docs/assets/app.js": {
      "type": "file",
      "content": "console.log('docs spa booted');\n"
    },
    "/var/log/nginx": { "type": "dir" },
    "/var/log/nginx/access.log": {
      "type": "file",
      "content": "10.0.0.4 - - [04/Mar/2025:18:01:11 +0000] \"GET / HTTP/1.1\" 200 132 \"-\" \"Mozilla/5.0\"\n10.0.0.9 - - [04/Mar/2025:18:01:33 +0000] \"GET /assets/app.js HTTP/1.1\" 200 31 \"-\" \"Mozilla/5.0\"\n10.0.0.7 - - [04/Mar/2025:18:01:42 +0000] \"GET /guides/getting-started HTTP/1.1\" 404 162 \"-\" \"Mozilla/5.0\"\n10.0.0.7 - - [04/Mar/2025:18:02:05 +0000] \"GET /guides/getting-started HTTP/1.1\" 404 162 \"-\" \"Mozilla/5.0\"\n"
    }
  },
  "grader": {
    "strategy": "final-fs-state",
    "expectedFs": [
      {
        "path": "/home/dev/reports/docs-spa-fix.note",
        "exists": true,
        "type": "file",
        "contentContains": [
          "docs.example.com",
          "/guides/getting-started",
          "try_files $uri $uri/ /index.html"
        ]
      }
    ],
    "requireCommands": ["cat", "ls", "grep", "echo"]
  }
}
