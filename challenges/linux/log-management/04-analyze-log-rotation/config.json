{
  "cwd": "/home/dev",
  "env": { "USER": "dev", "HOME": "/home/dev" },
  "fs": {
    "/home/dev": { "type": "dir" },
    "/etc": { "type": "dir" },
    "/etc/logrotate.d": { "type": "dir" },
    "/etc/logrotate.d/nginx-orders": {
      "type": "file",
      "content": "/var/log/nginx/*.log {\n    daily\n    rotate 14\n    missingok\n    compress\n    delaycompress\n    notifempty\n    create 0640 www-data adm\n    sharedscripts\n    postrotate\n        systemctl reload nginx >/dev/null 2>&1 || true\n    endscript\n}\n"
    },
    "/var/log": { "type": "dir" },
    "/var/log/nginx": { "type": "dir" },
    "/var/log/nginx/access.log": { "type": "file", "content": "current requests\n", "size": 734003200 },
    "/var/log/nginx/access.log.1": { "type": "file", "content": "yesterday requests\n", "size": 524288000 },
    "/var/log/nginx/access.log.2.gz": { "type": "file", "content": "compressed older requests\n", "size": 73400320 },
    "/var/log/nginx/error.log": { "type": "file", "content": "current errors\n", "size": 20971520 },
    "/var/log/nginx/error.log.1": { "type": "file", "content": "yesterday errors\n", "size": 5242880 }
  },
  "grader": {
    "strategy": "contains",
    "source": "all-stdout",
    "loose": true,
    "expected": [
      "daily",
      "rotate 14",
      "compress",
      "delaycompress",
      "access.log.2.gz"
    ],
    "requireCommands": ["cat", "ls", "grep"]
  }
}
