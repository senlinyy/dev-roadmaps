{
  "cwd": "/home/dev",
  "env": { "USER": "dev", "HOME": "/home/dev" },
  "fs": {
    "/home/dev": { "type": "dir" }
  },
  "grader": {
    "strategy": "final-fs-state",
    "expectedFs": {
      "/home/dev/pathutil.sh": {
        "type": "file",
        "contentContains": "${filepath%/*}"
      },
      "/home/dev/greet.sh": {
        "type": "file",
        "contentContains": "local "
      }
    },
    "requireCommands": ["chmod"]
  }
}
